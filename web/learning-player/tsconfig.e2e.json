{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true
  },
  "include": [
    "playwright.config.ts",
    "playwright.validation.config.ts",
    "e2e/**/*.ts"
  ]
}
