    },
    {
      "id": "quote:fd1ae6059f7ce437",
      "type": "Quote",
      "properties": {
        "text": "People that run businesses understand that people make mistakes. They never will forgive software for making a mistake.",
        "episode_id": "4255b42e-3a9e-11f1-8eee-179e850fd703",
        "speaker_id": null,
