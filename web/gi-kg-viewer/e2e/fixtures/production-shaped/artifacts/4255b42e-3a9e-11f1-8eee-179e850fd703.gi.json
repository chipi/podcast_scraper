    {
      "id": "quote:8e5e96951f944d45",
      "type": "Quote",
      "properties": {
        "text": "to replace an enterprise platform in this SaaSpocalypse that people talk about is an extraordinary expense.",
        "episode_id": "4255b42e-3a9e-11f1-8eee-179e850fd703",
        "speaker_id": null,
        "char_start": 0,
