      "id": "quote:17655de9c1927ad8",
      "type": "Quote",
      "properties": {
        "text": "This week, the AI backlash has turned violent.",
        "episode_id": "25d702f6-ed6a-4565-8065-e729eb0f2650",
        "speaker_id": null,
        "char_start": 1314,
