    {
      "id": "insight:499e7f5ac4043bf3",
      "type": "Insight",
      "properties": {
        "text": "The dinosaur fossil market is relatively underdeveloped compared to established art markets.",
        "episode_id": "f7957569-770c-45d3-a4e4-b43c01323ab8",
        "grounded": true,
        "insight_type": "fact",
        "position_hint": 0.13
      },
      "confidence": 1.0
    },
    {
      "id": "quote:a412be0d73aca9fe",
      "type": "Quote",
      "properties": {
        "text": "Speaker 4: to resemble other areas of the art market, but it's",
        "episode_id": "f7957569-770c-45d3-a4e4-b43c01323ab8",
        "speaker_id": null,
        "char_start": 7290,
        "char_end": 7352,
        "timestamp_start_ms": 362640,
        "timestamp_end_ms": 366160,
        "transcript_ref": "transcripts/0002 - Inside the Booming Market for Dinosaur Fossils_20260506-135048_ba02775e.txt"
      }
    },
    {
      "id": "quote:7ce96b73d91fe5dc",
      "type": "Quote",
      "properties": {
        "text": "Speaker 4: being that it's a very underdeveloped, recent, recently growing and",
        "episode_id": "f7957569-770c-45d3-a4e4-b43c01323ab8",
        "speaker_id": null,
        "char_start": 7423,
        "char_end": 7501,
