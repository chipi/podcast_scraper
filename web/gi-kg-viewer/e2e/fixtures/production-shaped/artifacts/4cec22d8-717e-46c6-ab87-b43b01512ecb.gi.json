      "type": "Quote",
      "properties": {
        "text": "So the thesis behind forming Blackrock was that we could actually",
        "episode_id": "4cec22d8-717e-46c6-ab87-b43b01512ecb",
        "speaker_id": null,
        "char_start": 6520,
