    {
      "id": "insight:b68d7c753e76c602",
      "type": "Insight",
      "properties": {
        "text": "Finance has experienced significant shifts, including the growth of asset management, the pervasive influence of technology, the expansion of private markets, and the consolidation of market power among a few large entities.",
        "episode_id": "4cec22d8-717e-46c6-ab87-b43b01512ecb",
        "grounded": true,
        "insight_type": "fact",
        "position_hint": 0.02
      },
      "confidence": 1.0
    },
    {
      "id": "quote:69f40b55c213aba8",
      "type": "Quote",
      "properties": {
        "text": "then you have this extraordinary growth in the asset management industry.",
        "episode_id": "4cec22d8-717e-46c6-ab87-b43b01512ecb",
        "speaker_id": null,
        "char_start": 692,
        "char_end": 765,
