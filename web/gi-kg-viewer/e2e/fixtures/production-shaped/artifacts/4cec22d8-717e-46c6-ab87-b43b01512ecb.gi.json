        "grounded": true,
        "insight_type": "opinion",
        "position_hint": 0.04
      },
      "confidence": 1.0
    },
    {
      "id": "quote:1e7b0295dc12b657",
      "type": "Quote",
      "properties": {
        "text": "to become productive, useful technology for finance.",
        "episode_id": "4cec22d8-717e-46c6-ab87-b43b01512ecb",
