# Optional: pre-fill corpus path in the dev shell (absolute path to pipeline output).
# VITE_DEFAULT_CORPUS_PATH=/Users/you/projects/podcast_scraper/output

# Optional: max extra sibling episodes loaded per graph merge (topic_clusters.json); default 10.
# VITE_CLUSTER_SIBLING_EPISODE_CAP=10

# Optional: PostHog Cloud project token (public ``phc_...``). Leave unset for no analytics.
# VITE_POSTHOG_PROJECT_TOKEN=
# Ingestion API host — EU Cloud default matches ``main.ts`` fallback when unset.
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
