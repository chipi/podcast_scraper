metrics/*.json
metrics/*.jsonl
metrics/index.html

# Ad-hoc experiment batch log (machine-local; regenerate from your runs if needed)
docs/wip/_batch_experiment_log.txt

# Agent journal — persistent, machine-local working notes (plans/approaches/logs/
