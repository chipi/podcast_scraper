// podcast_scraper-prod tailnet ACL.
//
// Synced to the live Tailscale ACL by infra/terraform/tailscale.tf's
// tailscale_acl resource on every `tofu apply`.
//
// Owner: single operator. Add a collaborator by appending their tailnet
// identity to acls below and opening a PR. RFC-082 Decision 2 + Decisions-made #4.

{
  // Tag ownership. Only listed owners can apply these tags to devices.
  //   tag:prod         → the prod VPS (advertised by cloud-init's `tailscale up`)
  //   tag:dr-drill     → Hetzner DR drill VPS (workspace drill; RFC-082 #752)
  //   tag:gha-deployer → ephemeral GHA runner during deploy-prod.yml / drill-e2e
  //   tag:dgx-llm-host → operator DGX Spark (RFC-089); Ollama + embedding shim
  "tagOwners": {
    "tag:prod":         ["autogroup:admin"],
    "tag:dr-drill":     ["autogroup:admin"],
    "tag:gha-deployer": ["autogroup:admin"],
    "tag:dgx-llm-host": ["autogroup:admin"]
  },

  // Implicit-deny for everything else; only listed traffic is permitted.
  "acls": [
    // Operator's own devices (laptop, phone, iPad — anyone with admin role)
    // reach the viewer + api over HTTPS, AND SSH for hands-on debugging
    // and the operator bootstrap flow (stage .env, restart unit).
    // Originally restricted SSH to tag:gha-deployer only, but that blocked
    // operator-side bootstrap (no way to stage host secrets); pragmatic to
    // grant SSH to admin too. Defence-in-depth still applies via SSH key auth.
    //
    // :8443 = orrery co-tenant tailnet publish (chipi/podcast_scraper#838,
    // chipi/orrery#260). orrery's web app at :8090 fronted via tailscale
    // serve on :8443, leaving :443 for podcast_scraper.
    {
      "action": "accept",
      "src":    ["autogroup:admin"],
      "dst":    ["tag:prod:22,80,443,8443"]
    },

    // Deploy workflow (ephemeral GHA runner under tag:gha-deployer) SSHes into
    // the VPS to run `docker compose pull && up`. SSH + the orrery external
    // healthcheck on :8443 — no other ports.
    {
      "action": "accept",
      "src":    ["tag:gha-deployer"],
      "dst":    ["tag:prod:22,8443"]
    },

    // DR drill VPS — operator + GHA reach SSH and viewer/api over HTTPS.
    // MagicDNS https://<host>.<tailnet>/ requires `tailscale serve` on the
    // node (cloud-init wires ExecStartPost on podcast-scraper.service); ACL
    // alone is not enough if serve was never started.
    {
      "action": "accept",
      "src":    ["autogroup:admin"],
      "dst":    ["tag:dr-drill:22,80,443"]
    },
    {
      "action": "accept",
      "src":    ["tag:gha-deployer"],
      "dst":    ["tag:dr-drill:22,80,443"]
    },

    // RFC-089 / ADR-096 / #814 / #926 / #953:
    //   :11434 = DGX Ollama (LLM stages).
    //   :8000  = faster-whisper-server / speaches (transcription stage; #814).
    //   :8001  = pyannote diarization service (#926; #943 adds /metrics).
    //   :8002  = openai-whisper service (first-party Whisper code; #953).
    //            Runs alongside speaches:8000 until #952 picks the winner.
    // #943 observability sidecars:
    //   :8080  = cAdvisor (per-container resource use).
    //   :9100  = node-exporter (host CPU/mem/disk/net).
    //   :9400  = DCGM exporter (per-GPU util/mem/temp/power).
    // Cloud fallback is enforced in profile config, not the ACL.
    {
      "action": "accept",
      "src":    ["autogroup:admin", "tag:gha-deployer"],
      "dst":    ["tag:dgx-llm-host:11434", "tag:dgx-llm-host:8000", "tag:dgx-llm-host:8001", "tag:dgx-llm-host:8002", "tag:dgx-llm-host:8080", "tag:dgx-llm-host:9100", "tag:dgx-llm-host:9400"]
    },
    {
      "action": "accept",
      "src":    ["tag:dr-drill"],
      "dst":    ["tag:dgx-llm-host:11434", "tag:dgx-llm-host:8000", "tag:dgx-llm-host:8001", "tag:dgx-llm-host:8002"]
    },
    {
      "action": "accept",
      "src":    ["tag:prod"],
      "dst":    ["tag:dgx-llm-host:11434", "tag:dgx-llm-host:8000", "tag:dgx-llm-host:8001", "tag:dgx-llm-host:8002", "tag:dgx-llm-host:8080", "tag:dgx-llm-host:9100", "tag:dgx-llm-host:9400"]
    }

    // (Future, for #714 + #723) Home Assistant subscribes to /api/jobs.
    // Uncomment and add HA's tailnet identity once that integration lands.
    // ,
    // {
    //   "action": "accept",
    //   "src":    ["user:homeassistant@example.com"],
    //   "dst":    ["tag:prod:443"]
    // }
  ],

  // No auto-approvers — manual approval for any new tagged device, slowing
  // down the bad-key compromise path.
  "autoApprovers": {
    "routes":   {},
    "exitNode": []
  },

  // Tailscale SSH — narrowly enabled for the DGX host only (RFC-089 / #897
  // post-merge). Operator (autogroup:admin) reaches dgx-llm-host as either
  // markodragoljevic (the actual login user) or root (emergencies). Tailnet
  // identity authenticates; no SSH keys to manage on the operator side.
  //
  // Prod / drill VPSes intentionally NOT covered — they keep classic key-
  // based SSH so prod's auth model is identical between operator and CI
  // (deploy-prod.yml uses an SSH key in GHA). Don't widen this block to
  // tag:prod / tag:dr-drill without revisiting that design.
  "ssh": [
    {
      "action": "accept",
      "src":    ["autogroup:admin"],
      "dst":    ["tag:dgx-llm-host"],
      "users":  ["markodragoljevic", "root"]
    }
  ]
}
