{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "metrics_summarization_v2.json",
  "title": "Summarization Metrics (v2 — scorer intrinsic layout)",
  "description": "Matches metrics.json emitted by podcast_scraper.evaluation.scorer (nested intrinsic, episode_count, avg_latency_ms).",
  "type": "object",
  "additionalProperties": true,
  "required": ["task", "dataset_id", "schema", "episode_count", "intrinsic"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "metrics_summarization_v2"
    },
    "task": {
      "type": "string",
      "const": "summarization"
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string"
    },
    "episode_count": {
      "type": "integer",
      "minimum": 0
    },
    "intrinsic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["gates", "warnings", "length", "performance"],
      "properties": {
        "gates": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "boilerplate_leak_rate",
            "speaker_label_leak_rate",
            "truncation_rate",
            "failed_episodes",
            "episode_gate_failures"
          ],
          "properties": {
            "boilerplate_leak_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "speaker_label_leak_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "truncation_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "failed_episodes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "episode_gate_failures": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "warnings": {
          "type": "object",
          "additionalProperties": true,
          "required": ["speaker_name_leak_rate"],
          "properties": {
            "speaker_name_leak_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "length": {
          "type": "object",
          "additionalProperties": true,
          "required": ["avg_tokens", "min_tokens", "max_tokens"],
          "properties": {
            "avg_tokens": {
              "type": "number",
              "minimum": 0
            },
            "min_tokens": {
              "type": "number",
              "minimum": 0
            },
            "max_tokens": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "performance": {
          "type": "object",
          "additionalProperties": true,
          "required": ["avg_latency_ms"],
          "properties": {
            "avg_latency_ms": {
              "type": "number",
              "minimum": 0
            },
            "median_latency_ms": {
              "type": "number",
              "minimum": 0
            },
            "p95_latency_ms": {
              "type": "number",
              "minimum": 0
            },
            "avg_latency_ms_excluding_first": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cost": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "vs_reference": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
