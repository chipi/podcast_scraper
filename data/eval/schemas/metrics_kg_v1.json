{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "metrics_kg_v1.json",
  "title": "Knowledge Graph Eval Metrics (v1)",
  "type": "object",
  "additionalProperties": true,
  "required": ["task", "schema", "reference_id", "dataset_id", "scored_episodes"],
  "properties": {
    "schema": { "type": "string", "const": "metrics_kg_v1" },
    "task": { "type": "string", "const": "knowledge_graph" },
    "reference_id": { "type": "string", "minLength": 1 },
    "dataset_id": { "type": "string", "minLength": 1 },
    "scored_episodes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scored", "total"],
      "properties": {
        "scored": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "node_edge_count_exact_match_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "counts": { "type": "object", "additionalProperties": true }
  }
}
