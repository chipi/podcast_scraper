        "char_start": 296,
        "episode_id": "ep-febd9a8f53bf3a3a",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Adobe. Adobe Creative Cloud puts Lightroom, Photoshop, and Premiere on every device. Try adobe.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p04_e01.txt"
