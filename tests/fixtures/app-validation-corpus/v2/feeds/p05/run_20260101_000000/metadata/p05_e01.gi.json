        "speaker_id": "person:speaker-01",
        "text": "Welcome back to Long Horizon Notes. Today we're talking about index investing, and I'm joined by Daniel, former bond trader turned index advocate. Daniel, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
        "transcript_ref": "transcripts/p05_e01.txt"
