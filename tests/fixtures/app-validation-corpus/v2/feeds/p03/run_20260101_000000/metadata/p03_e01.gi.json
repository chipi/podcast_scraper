        "char_start": 6,
        "episode_id": "ep-2a703b6f57d9020f",
        "speaker_id": "person:speaker-01",
        "text": "Welcome back to Below the Surface. Today we're talking about wreck diving, and I'm joined by Marco, technical diver and underwater archaeologist. Marco, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
        "transcript_ref": "transcripts/p03_e01.txt"
      },
      "type": "Quote"
    },
    {
      "id": "person:speaker-02",
