      "properties": {
        "char_end": 232,
        "char_start": 200,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Ethan. Great to be back.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
