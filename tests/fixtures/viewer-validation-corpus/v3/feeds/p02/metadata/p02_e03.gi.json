        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Vanta. Vanta automates SOC 2 and ISO compliance. Try vanta.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
