        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-01",
        "text": "Before we get into it — I was last on the show talking about on-call rotations. The pattern shows up again here.",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
