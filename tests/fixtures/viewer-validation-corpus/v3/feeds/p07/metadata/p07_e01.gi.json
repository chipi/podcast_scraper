        "episode_id": "5ef53e66-e083-5fcb-b555-a3814ebb6b39",
        "speaker_id": "person:speaker-01",
        "text": "Welcome back to The Long View \u2014 Sustainability. Today we're talking about sustainability, and I'm joined by Dr. Elena Fischer, sustainability researcher and systems thinker. Dr. Elena Fischer, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
