    },
    {
      "id": "quote:f20ec1121f1cbb8d",
      "properties": {
        "char_end": 372,
        "char_start": 248,
        "episode_id": "5ef53e66-e083-5fcb-b555-a3814ebb6b39",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Alex Morgan. Excited for this one \u2014 sustainability and systems thinking is something I've been thinking about a lot.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p07_e01.txt"
      },
      "type": "Quote"
    },
    {
