      "properties": {
        "char_end": 504,
        "char_start": 386,
        "episode_id": "5ef53e66-e083-5fcb-b555-a3814ebb6b39",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Notion. Notion replaces the dozen tools your team is half-using. Try notion.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p07_e01.txt"
      },
      "type": "Quote"
    },
    {
