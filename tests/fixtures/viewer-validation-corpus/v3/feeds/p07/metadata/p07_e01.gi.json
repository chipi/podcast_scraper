      "properties": {
        "char_end": 584,
        "char_start": 504,
        "episode_id": "5ef53e66-e083-5fcb-b555-a3814ebb6b39",
        "speaker_id": "person:speaker-01",
        "text": "That's a useful framing. Where do systems thinking and sustainability intersect?",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p07_e01.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:d60518fdb3b7b7f6",
      "properties": {
        "char_end": 846,
        "char_start": 604,
        "episode_id": "5ef53e66-e083-5fcb-b555-a3814ebb6b39",
        "speaker_id": "person:speaker-02",
        "text": "Let me give you the version I actually believe. Sustainability is a systems-thinking problem before it's an environmental problem. We've seen this play out at teams using Carbon Trust. And the second-order effect is the part most people miss.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p07_e01.txt"
      },
      "type": "Quote"
    },
