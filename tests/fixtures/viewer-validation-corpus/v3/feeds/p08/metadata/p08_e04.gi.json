        "episode_id": "1b3a6ea0-3cfe-5f9b-a562-a0e49e2b4130",
        "speaker_id": "person:speaker-01",
        "text": "Push back on the conventional wisdom for me. What's the version of the question that actually matters?",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p08_e04.txt"
