        "char_start": 732,
        "episode_id": "1c0614c2-9f65-5fd5-9340-ab8c6059d014",
        "speaker_id": "person:speaker-01",
        "text": "Walk me through a concrete example. How does BBC fit into this picture?",
        "timestamp_end_ms": 36000,
        "timestamp_start_ms": 30000,
