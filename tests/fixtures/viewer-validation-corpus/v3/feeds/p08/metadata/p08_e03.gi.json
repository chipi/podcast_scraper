      "properties": {
        "char_end": 409,
        "char_start": 263,
        "episode_id": "1c0614c2-9f65-5fd5-9340-ab8c6059d014",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Squarespace. Squarespace makes building a beautiful, branded website actually pleasant. Try squarespace.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p08_e03.txt"
      },
