    {
      "id": "quote:0e825b91fd93944b",
      "properties": {
        "char_end": 244,
        "char_start": 201,
        "episode_id": "1c0614c2-9f65-5fd5-9340-ab8c6059d014",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, A. correspondent. Great to be back.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p08_e03.txt"
      },
      "type": "Quote"
