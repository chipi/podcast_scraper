        "episode_id": "15a1cbea-1449-50ac-bb1c-11784d7421c3",
        "speaker_id": "person:speaker-01",
        "text": "This episode is brought to you by Squarespace. Squarespace makes building a beautiful, branded website actually pleasant. Get started at squarespace.com/podcast.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
