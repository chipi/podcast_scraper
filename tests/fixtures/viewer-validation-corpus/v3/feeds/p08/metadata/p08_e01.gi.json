        "speaker_id": "person:speaker-02",
        "text": "Yeah, so \u2014 Public radio voice is a deliberate style, not an accident. We've seen this play out at teams using BBC. I've watched this pattern hold across three different teams.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p08_e01.txt"
