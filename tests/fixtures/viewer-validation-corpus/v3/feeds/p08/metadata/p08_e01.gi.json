      "id": "quote:d2da2497eeb3919b",
      "properties": {
        "char_end": 319,
        "char_start": 203,
        "episode_id": "15a1cbea-1449-50ac-bb1c-11784d7421c3",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, A. correspondent. Excited for this one \u2014 public-radio reporting is something I've been thinking about a lot.",
