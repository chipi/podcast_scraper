        "char_start": 499,
        "episode_id": "15a1cbea-1449-50ac-bb1c-11784d7421c3",
        "speaker_id": "person:speaker-01",
        "text": "I want to dig into that. What's something you used to believe about this that you've revised?",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p08_e01.txt"
      },
      "type": "Quote"
    },
    {
