        "char_start": 743,
        "episode_id": "ac5784fa-1c94-5cd8-99c6-c4f0be157a64",
        "speaker_id": "person:speaker-01",
        "text": "What's the one heuristic you keep coming back to? What's something you used to believe about this that you've revised?",
        "timestamp_end_ms": 36000,
