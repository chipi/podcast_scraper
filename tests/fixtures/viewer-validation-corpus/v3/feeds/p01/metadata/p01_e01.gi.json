      "properties": {
        "char_end": 422,
        "char_start": 313,
        "episode_id": "5b39965f-22a2-54c9-9c42-e7a19d8da2da",
        "speaker_id": "person:speaker-01",
        "text": "This episode is brought to you by Strava. Strava is the home for athletes. Get started at strava.com/podcast.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p01_e01.txt"
