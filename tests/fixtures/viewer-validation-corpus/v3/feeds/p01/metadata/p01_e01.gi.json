        "speaker_id": "person:speaker-01",
        "text": "Welcome back to Singletrack Sessions. Today we're talking about trail building, and I'm joined by Liam Verbeek, trail builder for the Cascadia Alliance. Liam Verbeek, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
        "transcript_ref": "transcripts/p01_e01.txt"
      },
      "type": "Quote"
    },
    {
      "id": "person:speaker-02",
      "properties": {
        "name": "Liam Verbeek"
      },
      "type": "Person"
    },
    {
      "id": "quote:f6fc35aad65210f8",
      "properties": {
        "char_end": 306,
        "char_start": 210,
        "episode_id": "5b39965f-22a2-54c9-9c42-e7a19d8da2da",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Maya. Excited for this one \u2014 trail building is something I've been thinking about a lot.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p01_e01.txt"
      },
      "type": "Quote"
    },
    {
