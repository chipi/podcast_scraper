      "properties": {
        "char_end": 492,
        "char_start": 422,
        "episode_id": "5b39965f-22a2-54c9-9c42-e7a19d8da2da",
        "speaker_id": "person:speaker-01",
        "text": "Take me through the decision. How does RockShox fit into this picture?",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p01_e01.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:c842e5fe8b174fe5",
      "properties": {
        "char_end": 704,
        "char_start": 507,
        "episode_id": "5b39965f-22a2-54c9-9c42-e7a19d8da2da",
        "speaker_id": "person:speaker-02",
        "text": "Honestly, Drainage is the single highest-leverage design choice on any trail. We've seen this play out at teams using Cascadia Alliance. I've watched this pattern hold across three different teams.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p01_e01.txt"
