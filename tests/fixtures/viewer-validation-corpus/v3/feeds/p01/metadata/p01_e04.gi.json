        "grounded": true,
        "text": "# Singletrack Sessions — Episode\n## The Risk You Didn't Name\nHost: Maya\nGuest: Sophie Laurent\n#fixture-v3: voice=en-US host_voice=en-US\nMaya: Welcome back to Singletrack Sessions.",
        "insight_type": "unknown",
        "position_hint": 0.5
      },
