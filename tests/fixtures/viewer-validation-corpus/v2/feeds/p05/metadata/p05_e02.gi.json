        "char_start": 428,
        "episode_id": "78741d49-00ad-5f5f-b127-8fd1c1b6844c",
        "speaker_id": "person:speaker-01",
        "text": "Before we get into it — Daniel was on episode 1 making the case for behavioral discipline in index investing. The same discipline keeps you from buying the wrong building.",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p05_e02.txt"
      },
      "type": "Quote"
