        "episode_id": "78741d49-00ad-5f5f-b127-8fd1c1b6844c",
        "speaker_id": "person:speaker-01",
        "text": "Before we dive in, a quick word from our sponsor Wealthfront. Wealthfront automates the boring parts of investing — tax-loss harvesting, rebalancing, and high-yield cash. Use code POD for an extended trial.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
