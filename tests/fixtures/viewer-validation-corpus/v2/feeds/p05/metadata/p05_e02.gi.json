        "speaker_id": "person:speaker-02",
        "text": "Yeah, exactly. And it ties into what we're covering today.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p05_e02.txt"
      },
      "type": "Quote"
