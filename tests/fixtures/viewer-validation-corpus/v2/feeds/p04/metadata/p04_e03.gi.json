    {
      "id": "quote:f119403f8853e735",
      "properties": {
        "char_end": 163,
        "char_start": 5,
        "episode_id": "e1743bda-76ff-5586-9e39-3fa45e41ef9a",
        "speaker_id": "person:speaker-01",
        "text": "Welcome back to Frame & Light. Today we're talking about lighting design, and I'm joined by Elise, commercial lighting director. Elise, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
        "transcript_ref": "transcripts/p04_e03.txt"
      },
