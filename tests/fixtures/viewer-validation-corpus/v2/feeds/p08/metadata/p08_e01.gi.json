        "episode_id": "15a1cbea-1449-50ac-bb1c-11784d7421c3",
        "speaker_id": "person:speaker-02",
        "text": "I'd put it this way: Solar's learning curve was the most important industrial story of the last 40 years. Teams working with NREL run into this constantly. What used to feel like an exception is honestly the median case now.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p08_e01.txt"
