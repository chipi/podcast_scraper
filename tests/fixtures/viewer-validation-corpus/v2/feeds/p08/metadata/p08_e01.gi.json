        "speaker_id": "person:speaker-01",
        "text": "This episode is brought to you by Linear. Linear is the issue tracker built for speed \u2014 keyboard-first, fast search, and a clean roadmap view your team actually uses. Get started at linear.com/podcast.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
