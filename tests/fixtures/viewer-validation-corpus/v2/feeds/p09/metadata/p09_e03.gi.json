    },
    {
      "id": "quote:3305ca88e09a0b50",
      "properties": {
        "char_end": 260,
        "char_start": 201,
        "episode_id": "79fb44f3-5be0-5fc7-9d43-2f39049f7f2d",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Alex Morgan. This is a topic I've spent decades on.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p09_e03.txt"
      },
      "type": "Quote"
    },
    {
