    },
    {
      "id": "quote:99220ffdf5c66834",
      "properties": {
        "char_end": 177,
        "char_start": 7,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-01",
        "text": "Welcome back to Practical Systems. Today we're talking about security design, and I'm joined by Priya, principal SRE at a payments platform. Priya, thanks for being here.",
        "timestamp_end_ms": 6000,
        "timestamp_start_ms": 0,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
      "id": "person:speaker-02",
      "properties": {
        "name": "Priya"
      },
      "type": "Person"
    },
    {
      "id": "quote:c4a97578abf51afe",
      "properties": {
        "char_end": 217,
        "char_start": 185,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Ethan. Great to be back.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:a8939f522ceeddda",
      "properties": {
        "char_end": 386,
        "char_start": 225,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Vanta. Vanta automates SOC 2 and ISO compliance so you can focus on building, not on collecting screenshots. Try vanta.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:18df7b25298d216f",
      "properties": {
        "char_end": 539,
        "char_start": 386,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-01",
        "text": "Before we get into it — I was last on the show talking about on-call rotations. The pattern shows up again here — embed ownership where the work happens.",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:1218c8c935ade6c9",
      "properties": {
        "char_end": 605,
        "char_start": 547,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-02",
        "text": "Yeah, exactly. And it ties into what we're covering today.",
        "timestamp_end_ms": 30000,
        "timestamp_start_ms": 24000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
    },
    {
      "id": "quote:5351b48f497b915e",
      "properties": {
        "char_end": 764,
        "char_start": 605,
        "episode_id": "d2fb36a0-6f97-55ee-a67a-e97dba3b7f27",
        "speaker_id": "person:speaker-02",
        "text": "I used to argue for a single central security team. I changed my mind after the 2024 webhook incident — the embedded model gets faster fixes and better signal.",
        "timestamp_end_ms": 36000,
        "timestamp_start_ms": 30000,
        "transcript_ref": "transcripts/p02_e03.txt"
      },
      "type": "Quote"
