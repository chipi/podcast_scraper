        "char_start": 411,
        "episode_id": "096240a2-e115-5a3c-98b4-2d852b096eda",
        "speaker_id": "person:speaker-01",
        "text": "Before we get into it \u2014 Priya was on episode 1 making the case that good on-call rotations are designed so waking up is rare. I want to push that further into how we communicate the design itself.",
        "timestamp_end_ms": 24000,
        "timestamp_start_ms": 18000,
        "transcript_ref": "transcripts/p02_e02.txt"
      },
      "type": "Quote"
    },
