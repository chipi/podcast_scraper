        "char_end": 231,
        "char_start": 199,
        "episode_id": "096240a2-e115-5a3c-98b4-2d852b096eda",
        "speaker_id": "person:speaker-02",
        "text": "Thanks, Ethan. Great to be back.",
        "timestamp_end_ms": 12000,
        "timestamp_start_ms": 6000,
        "transcript_ref": "transcripts/p02_e02.txt"
      },
      "type": "Quote"
