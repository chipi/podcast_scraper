        "char_start": 239,
        "episode_id": "096240a2-e115-5a3c-98b4-2d852b096eda",
        "speaker_id": "person:speaker-01",
        "text": "Today's episode is sponsored by Notion. Notion replaces the dozen tools your team is half-using with a single workspace for docs, projects, and wikis. Try notion.com today.",
        "timestamp_end_ms": 18000,
        "timestamp_start_ms": 12000,
        "transcript_ref": "transcripts/p02_e02.txt"
      },
      "type": "Quote"
    },
    {
