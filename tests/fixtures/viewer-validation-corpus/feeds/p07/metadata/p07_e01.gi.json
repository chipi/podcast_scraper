    {
      "id": "insight:aff029b964332002",
      "properties": {
        "confidence": 0.7,
        "grounded": true,
        "text": "Elena Fischer\n\nAlex Morgan: Today\u2019s topic is sustainability\u2014what it means, why it\u2019s everywhere, and what it requires in practice."
