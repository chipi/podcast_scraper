# infra/.env.dgx.local — operator-local DGX connection config sourced by
# `make dgx-ssh-test`, `make dgx-verify`, `make dgx-converge`.
# Copy this file to infra/.env.dgx.local (gitignored) and fill in values.
#
# Source for each value: see docs/guides/DGX_RUNBOOK.md + infra/dgx/converge/README.md.

# --- Runtime HTTP path (tailnet) -------------------------------------------
# How prod / dev / laptop talk to DGX Ollama (:11434) + embedding shim (:8001).
# MagicDNS hostname from `tailscale status` or login.tailscale.com/admin/machines.
# RFC-089 expects the stem to be dgx-llm or dgx-llm-N (the existing resolver enforces this).
export DGX_TAILNET_FQDN='dgx-llm-1.tail6d0ed4.ts.net'

# --- SSH path (operator laptop → DGX, for pyinfra) -------------------------
# Default = DGX_TAILNET_FQDN. Override if SSH-over-tailnet is blocked but LAN
# works (e.g. NVIDIA Sync's `spark-2c14.local` mDNS path).
export DGX_SSH_HOST="$DGX_TAILNET_FQDN"

# SSH user on DGX. Default root; set to your account if root login is disabled.
# When non-root, pyinfra escalates via sudo (passwordless sudo required).
export DGX_SSH_USER='root'

# Path to the private SSH key the operator laptop uses to reach DGX.
# Generate once with: ssh-keygen -t ed25519 -f ~/.ssh/dgx_ed25519
# Copy pubkey to DGX with:  ssh-copy-id -i ~/.ssh/dgx_ed25519.pub <user>@<host>
# Leave unset to use ssh-agent / default keys / ~/.ssh/config IdentityFile.
export DGX_SSH_KEY="$HOME/.ssh/dgx_ed25519"

# SSH port. Default 22.
export DGX_SSH_PORT='22'
