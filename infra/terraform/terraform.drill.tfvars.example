# Example tfvars for a throwaway DR *drill* stack (GitHub #752).
# Copy to a gitignored file (e.g. `terraform.drill.tfvars`) or pass with
#   tofu plan -var-file=terraform.drill.tfvars
# Secrets (`hcloud_token`, `tailscale_api_key`, SSH key material) must come
# from TF_VAR_* or a private -var-file — never commit them.

manage_tailscale_acl     = false
tailscale_advertise_tags = ["tag:dr-drill"]
tailnet_hostname         = "dr-podcast"
hcloud_environment_label = "drill"
# Ephemeral drill infra must be destroyable by the automated teardown — disable
# Hetzner delete/rebuild protection (PROD keeps it on via the var default).
enable_delete_protection = false

# Optional: allow inbound TCP/22 from these CIDRs for operator SSH when the tailnet is down.
# CI uses 0.0.0.0/0 and ::/0 in terraform.drill.ci.tfvars; use your /32 here for a tighter drill VM.
# hcloud_inbound_ssh_troubleshoot_cidrs = ["203.0.113.10/32"]

# Optional: smaller / cheaper while iterating (must match variables.tf validation).
# server_type = "cx33"
# CI uses ``terraform.drill.ci.tfvars``: ``hel1`` + ``cpx32`` by default (placement).
# location    = "nbg1"
