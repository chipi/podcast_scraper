# infra/.env.drill.local — operator-local drill Hetzner token (gitignored).
# Copy to infra/.env.drill.local and fill in the token from the drill-only
# Hetzner Cloud project (same credential as GitHub secret HCLOUD_TOKEN_DRILL).
#
# Load into your current shell (Make cannot export into the parent shell):
#   set -a && . ./infra/.env.drill.local && set +a
#
# Or run the orphan cleanup without exporting manually:
#   make delete-drill-hetzner-orphans

# Drill-only Hetzner project token (NEVER the prod token). Used by the orphan
# sweep and (mapped to TF_VAR_hcloud_token) by `make drill-tofu-*`.
export HCLOUD_TOKEN_DRILL='<paste-drill-project-read-write-api-token>'

# Optional: so `hcloud` CLI uses the same token when HCLOUD_TOKEN is the default.
# export HCLOUD_TOKEN="$HCLOUD_TOKEN_DRILL"

# --- Required for `make drill-tofu-plan|apply|destroy` (local drill OpenTofu, #1027) ---
# These map to the TF_VAR_* the config requires (same as the GHA drill-infra-* secrets/vars).
# The orphan sweep (make delete-drill-hetzner-orphans) does NOT need them — only the tofu targets do.
export TS_API_KEY='<tailscale-api-key — TF_VAR_tailscale_api_key>'
export OPERATOR_SSH_PUBLIC_KEY='<operator ssh public key — TF_VAR_ssh_public_key>'
export TAILNET_NAME='<tailnet, e.g. tailXXXXXX.ts.net — TF_VAR_tailscale_tailnet>'
#
# State decryption: the drill state (terraform.tfstate.enc.drill) is sops/age-encrypted.
# The wrapper auto-uses ~/.config/sops/age/keys.txt if present; otherwise export
# SOPS_AGE_KEY_FILE (path) or SOPS_AGE_KEY (key material) for the drill recipient.
