# infra/.env.drill.local — operator-local drill Hetzner token (gitignored).
# Copy to infra/.env.drill.local and fill in the token from the drill-only
# Hetzner Cloud project (same credential as GitHub secret HCLOUD_TOKEN_DRILL).
#
# Load into your current shell (Make cannot export into the parent shell):
#   set -a && . ./infra/.env.drill.local && set +a
#
# Or run the orphan cleanup without exporting manually:
#   make delete-drill-hetzner-orphans

export HCLOUD_TOKEN_DRILL='<paste-drill-project-read-write-api-token>'

# Optional: so `hcloud` CLI uses the same token when HCLOUD_TOKEN is the default.
# export HCLOUD_TOKEN="$HCLOUD_TOKEN_DRILL"
