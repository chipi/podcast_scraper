# infra/.env.local — operator-local secrets sourced by `make infra-plan` and
# `make infra-apply`. Copy this file to infra/.env.local (which is gitignored)
# and fill in values from your secrets store.
#
# Why a file instead of `export X=...` in your shell: this way you don't have
# to re-export 5+ variables every time you open a new terminal. The file is
# bind-mode 600-equivalent (gitignored, your local-fs permissions only).
#
# Where each value comes from: see docs/guides/PROD_RUNBOOK.md
# "First-time bootstrap" + "Tailscale credentials".

# Hetzner Cloud API token (Read+Write, scoped to podcast-scraper-prod project).
# Source: Hetzner console → Cloud → podcast-scraper-prod → Security → API Tokens.
export HCLOUD_TOKEN='<paste-hetzner-cloud-api-token>'
export TF_VAR_hcloud_token="$HCLOUD_TOKEN"

# Tailscale Personal API access token (Free-plan substitute for OAuth).
# Source: Tailscale admin → Settings → Keys → "API access tokens" tab.
# NOT the same as the device-join auth key (TS_AUTHKEY) — see RFC-082 Decision 2.
export TF_VAR_tailscale_api_key='<paste-tskey-api-...>'

# Your tailnet name (the MagicDNS suffix). Get with: tailscale status --json | jq -r .MagicDNSSuffix
export TF_VAR_tailscale_tailnet='tail6d0ed4.ts.net'

# Your laptop's SSH public key — cloud-init bakes it into deploy@<host>:~/.ssh/authorized_keys.
export TF_VAR_ssh_public_key="$(cat ~/.ssh/id_ed25519.pub)"

# === Optional overrides — uncomment + edit if you want to deviate from defaults ===

# Server type. Default: cx43 (8 vCPU shared Intel/AMD, 16 GB, EUR 15.11/mo).
# Alternatives: cax31 (ARM Ampere anti-jitter swap), ccx23 (dedicated AMD escalation).
# See RFC-082 Decision 1 for the trade-offs.
# export TF_VAR_server_type='cx43'

# Detached Volume size (GB) for the corpus. 0 = no Volume (boot disk used).
# Recommended once corpus grows past ~20 GB; per RFC-082 Decision 4.
# export TF_VAR_volume_size_gb=0
