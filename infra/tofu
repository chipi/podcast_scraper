#!/usr/bin/env bash
# infra/tofu — sops-encrypted-state wrapper for OpenTofu.
#
# Decrypts terraform/terraform.tfstate.enc to terraform/terraform.tfstate
# before invoking tofu, re-encrypts on exit if state changed, and shreds the
# plaintext via a trap so a Ctrl-C mid-run doesn't leave decrypted state on
# disk.
#
# Operator setup: see infra/README.md.
#
# Usage:
#   cd infra && ./tofu init
#   cd infra && ./tofu plan
#   cd infra && ./tofu apply
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TF_DIR="$REPO_ROOT/infra/terraform"

# Workspace selector (RFC-082 / #752 — local parity with the GHA drill-infra-* jobs).
#   INFRA_WORKSPACE=prod  (default) → default OpenTofu workspace + terraform.tfstate.enc
#   INFRA_WORKSPACE=drill           → 'drill' workspace + terraform.tfstate.enc.drill
# The drill path NEVER reads or writes the prod state file, and selects the 'drill'
# OpenTofu workspace (via `tofu workspace select -or-create drill` before each non-init
# command), so `make drill-tofu-*` can run the DR-drill (incl. Plan A teardown) locally
# with zero risk of touching prod. The prod branch is byte-identical to the original wrapper.
INFRA_WORKSPACE="${INFRA_WORKSPACE:-prod}"
case "$INFRA_WORKSPACE" in
  prod | default)
    ENC_STATE="$TF_DIR/terraform.tfstate.enc"
    PLAIN_STATE="$TF_DIR/terraform.tfstate"
    BACKUP_STATE="$TF_DIR/terraform.tfstate.backup"
    ;;
  drill)
    ENC_STATE="$TF_DIR/terraform.tfstate.enc.drill"
    PLAIN_STATE="$TF_DIR/terraform.tfstate.d/drill/terraform.tfstate"
    BACKUP_STATE="$TF_DIR/terraform.tfstate.d/drill/terraform.tfstate.backup"
    mkdir -p "$TF_DIR/terraform.tfstate.d/drill"
    # NOTE: we do NOT export TF_WORKSPACE here — setting it during `init` triggers a
    # state-migration prompt that -input=false rejects. Instead the workspace is
    # selected (-or-create) just before non-init commands below, matching the GHA flow.
    echo "[infra/tofu] WORKSPACE=drill — state: terraform.tfstate.enc.drill (prod state NOT touched)." >&2
    ;;
  *)
    echo "ERROR: INFRA_WORKSPACE must be 'prod' or 'drill' (got: '$INFRA_WORKSPACE')." >&2
    exit 2
    ;;
esac

# Verify required dependencies up-front so we fail fast rather than half-way
# through a decrypt with no encryptor available.
for cmd in tofu sops age; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "ERROR: '$cmd' not in PATH. Install with: brew install opentofu sops age" >&2
    exit 127
  fi
done

# Auto-default SOPS_AGE_KEY_FILE if unset and the standard XDG path exists.
# sops on macOS doesn't auto-find ~/.config/sops/age/keys.txt; without this
# fallback, the operator has to remember to export SOPS_AGE_KEY_FILE in their
# shell or .env.local. The age-keygen output goes here per the PROD_RUNBOOK.
if [[ -z "${SOPS_AGE_KEY_FILE:-}" ]] && [[ -f "$HOME/.config/sops/age/keys.txt" ]]; then
  export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"
fi

# Cleanup: any plaintext state file (current or backup) is shredded on exit.
# The encrypted blob is the source of truth; plaintext is ephemeral.
#
# EXCEPTION: if sops failed to re-encrypt new state, DO NOT shred — the
# operator needs the plaintext to recover. Set SOPS_FAILED=1 below to opt
# out of the shred and surface a recovery message instead.
SOPS_FAILED=0
cleanup() {
  if [[ "$SOPS_FAILED" = "1" ]]; then
    echo "" >&2
    echo "WARNING: plaintext state preserved at:" >&2
    echo "  $PLAIN_STATE" >&2
    echo "Recover by fixing .sops.yaml and re-encrypting manually:" >&2
    echo "  sops -e $PLAIN_STATE > $ENC_STATE" >&2
    echo "  shred -u $PLAIN_STATE   # only after the .enc is saved" >&2
    return
  fi
  for f in "$PLAIN_STATE" "$BACKUP_STATE"; do
    if [[ -f "$f" ]]; then
      if command -v shred >/dev/null 2>&1; then
        # Linux/coreutils path: shred overwrites + unlinks atomically.
        shred -u "$f" 2>/dev/null || rm -f "$f"
      else
        # macOS path: just rm -f. The earlier `dd if=/dev/urandom` fallback was
        # an INFINITE LOOP (no count= parameter) that filled the disk over hours
        # if any cleanup got triggered. The secure-overwrite is theatre on APFS
        # anyway (copy-on-write means the original blocks aren't reused in place).
        # The plaintext was on disk for seconds; rm is sufficient.
        rm -f "$f"
      fi
    fi
  done
}
trap cleanup EXIT INT TERM

# Decrypt existing encrypted state, if any. (First-ever apply has none yet.)
if [[ -f "$ENC_STATE" ]]; then
  sops -d "$ENC_STATE" > "$PLAIN_STATE"
fi

# Hash of the plaintext before tofu runs — used to decide whether to re-encrypt.
PRE_HASH=""
[[ -f "$PLAIN_STATE" ]] && PRE_HASH=$(shasum -a 256 "$PLAIN_STATE" | awk '{print $1}')

# Run tofu against the terraform dir. We don't `set -e` around tofu because
# its non-zero exits (e.g. plan with diffs and -detailed-exitcode) are normal.
cd "$TF_DIR"
set +e
# In drill mode, ensure the 'drill' workspace is selected before any non-init command
# (init must run first on the default workspace; `workspace` commands manage it directly).
if [[ "$INFRA_WORKSPACE" == "drill" && "${1:-}" != "init" && "${1:-}" != "workspace" ]]; then
  tofu workspace select -or-create drill >&2 || {
    echo "[infra/tofu] ERROR: 'tofu workspace select -or-create drill' failed (run init first?)." >&2
    exit 1
  }
fi
tofu "$@"
TOFU_EXIT=$?
set -e

# Re-encrypt iff state changed (or appeared for the first time).
POST_HASH=""
[[ -f "$PLAIN_STATE" ]] && POST_HASH=$(shasum -a 256 "$PLAIN_STATE" | awk '{print $1}')

if [[ -n "$POST_HASH" && "$PRE_HASH" != "$POST_HASH" ]]; then
  echo "[infra/tofu] state changed; re-encrypting -> $ENC_STATE" >&2
  # Write to a sibling file then rename — atomic, never leaves a half-written
  # encrypted blob if sops dies mid-write. If sops fails (bad .sops.yaml,
  # missing key, etc.) we set SOPS_FAILED=1 so the trap-cleanup preserves
  # plaintext for operator recovery instead of shredding it.
  if sops -e "$PLAIN_STATE" > "$ENC_STATE.new" 2>&1; then
    mv "$ENC_STATE.new" "$ENC_STATE"
  else
    SOPS_FAILED=1
    rm -f "$ENC_STATE.new"
    echo "[infra/tofu] ERROR: sops re-encryption failed." >&2
    TOFU_EXIT=2
  fi
fi

exit "$TOFU_EXIT"
