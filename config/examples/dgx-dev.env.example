# DGX dev environment (RFC-089 Tier 1). Copy to .env and replace
# `your-dgx.tailnet.ts.net` below with your DGX's actual Tailscale MagicDNS
# hostname (visible in `tailscale status` on the operator machine).
#
# export $(grep -v '^#' config/examples/dgx-dev.env.example | xargs)

# Both DGX_TAILNET_HOST and DGX_TAILNET_FQDN refer to the same hostname.
# DGX_TAILNET_HOST is also read by the model registry's resolve_endpoint()
# to substitute `{dgx_tailnet_host}` placeholders in StageOption.endpoint
# templates (see src/podcast_scraper/providers/ml/model_registry.py).
DGX_TAILNET_FQDN=your-dgx.tailnet.ts.net
DGX_TAILNET_HOST=your-dgx.tailnet.ts.net

OLLAMA_API_BASE=http://your-dgx.tailnet.ts.net:11434/v1
VECTOR_EMBEDDING_ENDPOINT=http://your-dgx.tailnet.ts.net:8001/embed
