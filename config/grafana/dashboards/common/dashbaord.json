{
  "title": "App Overview - podcast_scraper",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "tags": [
    "app",
    "podcast_scraper"
  ],
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "env",
        "query": "prod,preprod",
        "options": [
          {
            "selected": true,
            "text": "prod",
            "value": "prod"
          },
          {
            "selected": false,
            "text": "preprod",
            "value": "preprod"
          }
        ],
        "current": {
          "selected": true,
          "text": "prod",
          "value": "prod"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "skipUrlSync": false
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "query": "label_values(http_requests_total{env=\"$env\"}, service)",
        "regex": "",
        "allValue": ".*",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "query": "label_values(http_requests_total{env=\"$env\",service=~\"$service\"}, endpoint)",
        "regex": "",
        "allValue": ".*",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "status_class",
        "type": "custom",
        "query": "2xx,3xx,4xx,5xx",
        "allValue": ".*",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "current": {
          "selected": false,
          "text": "auto",
          "value": "$__auto_interval_interval"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum by(service) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\", status=~\"5..\"}[$__rate_interval])) / sum by(service) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\"}[$__rate_interval])) * 100",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum by(service) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\"}[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 Latency",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "histogram_quantile(0.95, sum by(service, le) (rate(http_request_duration_seconds_bucket{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\"}[$__rate_interval])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top Failing Endpoints",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "topk(10, sum by(service, endpoint, status) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\", status=~\"5..\"}[$__rate_interval])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by Endpoint",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum by(endpoint) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\"}[$__rate_interval]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "4xx/5xx by Endpoint",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "sum by(endpoint, status) (rate(http_requests_total{env=\"$env\",service=~\"$service\", endpoint=~\"$endpoint\", status=~\"[45]..\"}[$__rate_interval]))",
          "legendFormat": "{{endpoint}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Deploy/Restart Logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-logs"
          },
          "expr": "{env=\"$env\",service_name=~\"$service\"} |~ \"(?i)(start|restart|deploy|shutdown|initializ)\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-logs"
          },
          "expr": "{env=\"$env\",service_name=~\"$service\"} |~ \"(?i)(error|exception|fatal|panic|fail)\"",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "uid": "podcast-scraper-overview",
  "time": {
    "from": "now-3h",
    "to": "now"
  }
}
