{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki for pipeline episode_metrics logs",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Ingestion throughput and stage timings from **pipeline container logs** already shipped to Loki (Grafana Agent → docker logs). Parses stdout lines containing `episode_metrics:` from `orchestration._log_episode_metrics` (transcribe_sec, summary_sec, audio_sec, retries, tokens, estimated_cost). **No new deploy required** if your prod stack already labels streams with **env** and **service_name** (see `compose/grafana-agent.yaml`). **Not in these log lines:** separate GI vs KG seconds, run-level `run.json` aggregates, or API Prometheus histograms — use Explore to confirm your label names if panels are empty.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "One sample per `episode_metrics:` line (episode finished through the metrics logger).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({env=\"$env\", service_name=~\"$service\"} |= `episode_metrics:` [$__auto]))",
          "legendFormat": "{{service_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Episodes completed (metric lines / interval)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Multi-feed CLI entry only; single-feed viewer runs do not emit this line.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
