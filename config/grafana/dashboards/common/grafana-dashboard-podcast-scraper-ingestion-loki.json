          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({env=\"$env\", service_name=~\"$service\"} |= `Starting multi-feed podcast scrape` [$__auto]))",
          "legendFormat": "{{service_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Multi-feed batch starts / interval",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
