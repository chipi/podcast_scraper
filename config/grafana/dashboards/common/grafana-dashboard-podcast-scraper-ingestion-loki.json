      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {env=\"$env\", service_name=~\"$service\"} |= `episode_metrics:` | regexp `transcribe_sec=(?P<transcribe_sec>[0-9]+(?:\\.[0-9]+)?)` | unwrap transcribe_sec [5m]) by (service_name)",
          "legendFormat": "p95 transcribe {{service_name}}",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {env=\"$env\", service_name=~\"$service\"} |= `episode_metrics:` | regexp `summary_sec=(?P<summary_sec>[0-9]+(?:\\.[0-9]+)?)` | unwrap summary_sec [5m]) by (service_name)",
          "legendFormat": "p95 summary {{service_name}}",
          "queryType": "range",
          "refId": "B"
        }
