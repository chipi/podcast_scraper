{
  "uid": "vps-podcast-app",
  "id": null,
  "title": "VPS — Podcast · App",
  "tags": ["vps", "podcast", "app"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "surface",
        "label": "Surface",
        "type": "custom",
        "query": "All : podcast-.* , Player : podcast-(search|listen) , Operator : podcast-jobs , Pipeline : podcast-pipeline",
        "current": { "text": "All", "value": "podcast-.*" },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "App events ($surface)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "queryType": "stats", "expr": "instance:prod-podcast AND job:~\"$surface\" | stats count() logs" } ]
    },
    {
      "id": 2, "type": "stat", "title": "API request rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum(rate(http_requests_total{instance=\"prod-podcast\",job=\"api\"}[$__rate_interval]))" } ]
    },
    {
      "id": 3, "type": "stat", "title": "API 5xx rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.01 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum(rate(http_requests_total{instance=\"prod-podcast\",job=\"api\",status=~\"5..\"}[$__rate_interval]))" } ]
    },
    {
      "id": 4, "type": "stat", "title": "LLM cost (24h, pipeline)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "queryType": "stats", "expr": "instance:prod-podcast AND job:podcast-pipeline AND event_type:llm_cost | stats sum(estimated_cost_usd) cost" } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "App event volume over time ($surface)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "queryType": "statsRange", "expr": "instance:prod-podcast AND job:~\"$surface\" | stats by (job) count() events" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "API latency p50/p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{instance=\"prod-podcast\",job=\"api\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{instance=\"prod-podcast\",job=\"api\"}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 7, "type": "logs", "title": "App events ($surface) — tail",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "refId": "A", "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "queryType": "instant", "expr": "instance:prod-podcast AND job:~\"$surface\"" } ]
    }
  ]
}
