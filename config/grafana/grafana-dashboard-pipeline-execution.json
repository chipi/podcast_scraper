{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource for pipeline stdout / episode_metrics",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Pipeline timing and throughput derived from **stdout** lines logged by `orchestration._log_episode_metrics` (`episode_metrics:` …). Matches Grafana Agent docker logs shipped to Loki with labels **env** and **service_name** (see `compose/grafana-agent.yaml`). Select pipeline services (e.g. `pipeline-llm`, `pipeline`). **Limits:** `workflow/jsonl_emitter.py` writes JSONL to disk only; unless you separately ingest `run.jsonl` into Loki, panels cannot mirror legacy **run_finished** / **episode_finished** JSON events (run-level LLM call totals, gi/kg failure counts, **errors_total**, etc.). **Multi-feed batch starts** use the CLI log line containing `Starting multi-feed podcast scrape`; single-feed runs only appear in episode counters.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Throughput (stdout)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "One count per line matching `episode_metrics:` (each completed episode metrics snapshot).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({env=\"$env\", service_name=~\"$service\"} |= `episode_metrics:` [$__auto]))",
          "legendFormat": "{{service_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Episode metric lines / interval",
      "type": "timeseries"
    },
